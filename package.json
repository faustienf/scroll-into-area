{
  "name": "scroll-into-area",
  "version": "1.0.2",
  "description": "♿️ Smooth scrolling an element into view of container",
  "keywords": [
    "scroll into view",
    "scrollIntoView",
    "smooth scroll",
    "scroll parents",
    "scroll",
    "smooth",
    "smooth-scroll",
    "easing"
  ],
  "type": "module",
  "types": "dist/scroll-into-area.d.ts",
  "main": "dist/scroll-into-area.cjs",
  "module": "dist/scroll-into-area.js",
  "exports": {
    ".": {
      "types": "./dist/scroll-into-area.d.ts",
      "require": {
        "types": "./dist/scroll-into-area.d.cts",
        "default": "./dist/scroll-into-area.cjs"
      },
      "import": "./dist/scroll-into-area.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "test": "vitest run",
    "check-types": "tsc",
    "build": "tsup src/scroll-into-area.ts --format cjs,esm --dts --minify --clean",
    "release:patch": "pnpm version patch",
    "preversion": "pnpm run check-types && pnpm run build",
    "postversion": "git add . && git push && git push --tags && pnpm publish",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faustienf/scroll-into-area.git"
  },
  "author": "@faustien",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/faustienf/scroll-into-area/issues"
  },
  "homepage": "https://github.com/faustienf/scroll-into-area#readme",
  "dependencies": {
    "easing-scroll": "^1.0.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/coverage-v8": "^4.0.18",
    "esbuild": "^0.27.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
